.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp

# Node / Bun
node_modules/
bun.lockb         # 旧版 Bun 二进制锁文件（已弃用）
# bun.lock 是现代 Bun 文本锁文件，需要提交以保证 CI frozen-lockfile 可重现
.env
.env.local
.env.*.local

# 仅本地的 meta 文档（spec / plan / brainstorm 等）
docs/superpowers/

# VitePress 缓存与构建产物
docs/.vitepress/cache/
docs/.vitepress/dist/

# 构建产物 & 缓存
dist/
.cache/

# 测试期间脚本生成的临时目录
.tmp-*/

# data/holdings/、data/changes/、data/insider-trades/ 改为入库 ——
# 由开发者本地 `bun run fetch:data` 刷新后提交，CI 只读不拉，避免 CI 上装 longbridge CLI
# 与触发 SEC EDGAR 限流。如需排除，在此重新加回。

# 构建时从 skills/*.skill 拷入，不需版本控制
public/skills/

# Brainstorm / 临时会话
.superpowers/
